# OpenFinance — production configuration example
#
# Copy to .env.production and fill in real values before deploying to a VPS.
#   cp .env.production.example .env.production
#
# Generate a strong webhook secret:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Never commit .env.production to version control.

# --- App security (required) ---
# Authentication is own-login (email + password). After deploying, create the
# first user inside the running container — there is no public signup:
#   docker compose -f docker-compose.prod.yml exec openfinance \
#       python scripts/create_user.py --email you@example.com
OPENFINANCE_ENV=production
OPENFINANCE_REQUIRE_AUTH=true
OPENFINANCE_PUBLIC_HEALTH=true

# Webhook secret for /webhooks/pluggy?token=... (dedicated strong secret).
OPENFINANCE_WEBHOOK_SECRET=change-me-generate-a-different-strong-token

# --- Pluggy integration ---
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_CLIENT_ID=change-me
PLUGGY_CLIENT_SECRET=change-me

# --- Caddy (reverse proxy / HTTPS) ---
# Set to the domain or subdomain pointing to this VPS.
OPENFINANCE_DOMAIN=finance.example.com
# Email used by Caddy/Let's Encrypt for certificate notifications.
ACME_EMAIL=admin@example.com

# DATABASE_URL is not set here: docker-compose.prod.yml always overrides it to
# sqlite:////data/openfinance.db (the persistent volume path inside the container).
