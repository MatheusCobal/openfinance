# --- Local development (non-Docker) ---
# For Docker Compose, DATABASE_URL is set automatically by docker-compose.yml
# to sqlite:////data/openfinance.db and does not need to be set here.
DATABASE_URL=sqlite:///./openfinance.db
PLUGGY_BASE_URL=https://api.pluggy.ai
PLUGGY_CLIENT_ID=your_client_id_here
PLUGGY_CLIENT_SECRET=your_client_secret_here

# OpenFinance security
# Local-first by default: auth is disabled so local dev and tests are unaffected.
#
# Authentication is own-login (email + password, Argon2id, HttpOnly session
# cookie). Users are provisioned out of band — there is no public signup:
#   python scripts/create_user.py --email you@example.com
#
# Before exposing the app externally, set:
#   OPENFINANCE_ENV=production
#   OPENFINANCE_REQUIRE_AUTH=true
# and create at least one user. The app refuses to start if
# OPENFINANCE_ENV=production and OPENFINANCE_REQUIRE_AUTH is not true.
OPENFINANCE_ENV=local
OPENFINANCE_REQUIRE_AUTH=false

# /health is public by default even with auth enabled (useful for monitoring).
# Set to false to require auth on /health too.
OPENFINANCE_PUBLIC_HEALTH=true

# Required only if you use Pluggy webhooks.  When set, the token is always
# validated on /webhooks/pluggy — even in local/dev mode with require_auth=false.
# Use a strong, dedicated secret.
OPENFINANCE_WEBHOOK_SECRET=
